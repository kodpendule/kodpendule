# Local development (venv + SQLite — no database server required)
# Copy to .env.local

DJANGO_SETTINGS_MODULE=config.settings.local

SECRET_KEY=dev-change-me-to-a-long-random-string
DEBUG=True
# USE_DEBUG_TOOLBAR=True
ALLOWED_HOSTS=localhost,127.0.0.1

# SQLite is configured in config/settings/local.py (db.sqlite3 in project root).
# Do not set DATABASE_URL here for local dev.

CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
LANGUAGE_CODE=sr
LOG_LEVEL=DEBUG
DB_LOG_LEVEL=WARNING

# Optional: SendGrid for real email in local dev (create key at app.sendgrid.com)
# SENDGRID_API_KEY=SG.xxxxxxxxx
# SHOP_NOTIFICATION_EMAIL=kodpendule@gmail.com

# Optional: override Google Maps embed URL (default: Karađorđeva 11, Vrdnik)
# GOOGLE_MAPS_EMBED_URL=https://www.google.com/maps/embed?pb=...

# Optional: test R2 locally (defaults to local media/ folder when USE_R2=False)
# USE_R2=True
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_ENDPOINT_URL=
# R2_CUSTOM_DOMAIN=
