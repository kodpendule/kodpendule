# Production / Render.com — set these in the Render dashboard
# (or copy to .env.production for a local production smoke test)

DJANGO_SETTINGS_MODULE=config.settings.production

SECRET_KEY=generate-a-long-random-secret
DEBUG=False
ALLOWED_HOSTS=your-service.onrender.com,yourdomain.rs

# Render injects this when you attach a PostgreSQL instance:
DATABASE_URL=postgres://user:password@host:5432/dbname

CSRF_TRUSTED_ORIGINS=https://your-service.onrender.com,https://yourdomain.rs
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_PRELOAD=False

LOG_LEVEL=INFO
# Cloudflare R2 — product images (set USE_R2=True on Render)
USE_R2=True
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT_URL=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_CUSTOM_DOMAIN=media.yourdomain.rs
