msgstr[0] "Napomena: vaše vreme je %s sat ispred servera."
msgstr[1] "Napomena: vaše vreme je %s sata ispred servera."
msgstr[2] "Napomena: vaše vreme je %s sati ispred servera."

msgid "Note: You are %s hour behind server time."
