msgid "Available %s"
msgstr "Dostupni %s"

msgid ""
"This is the list of available %s. You may choose some by selecting them in "
"the box below and then clicking the \"Choose\" arrow between the two boxes."
msgstr ""
"Ovo je lista dostupnih „%s“. Izaberite stavke u polju ispod i kliknite "
"strelicu „Izaberi“."

msgid "Type into this box to filter down the list of available %s."
msgstr "Kucajte ovde da suzite listu dostupnih „%s“."

msgid "Filter"
msgstr "Filter"

msgid "Choose all"
msgstr "Izaberi sve"

msgid "Click to choose all %s at once."
msgstr "Kliknite da izaberete sve „%s“ odjednom."

msgid "Choose"
msgstr "Izaberi"

msgid "Remove"
msgstr "Ukloni"

msgid "Chosen %s"
msgstr "Izabrano „%s“"

msgid ""
"This is the list of chosen %s. You may remove some by selecting them in the "
"box below and then clicking the \"Remove\" arrow between the two boxes."
msgstr ""
"Ovo je lista izabranih „%s“. Uklonite stavke u polju ispod i kliknite "
"strelicu „Ukloni“."

msgid "Type into this box to filter down the list of selected %s."
msgstr "Kucajte ovde da suzite listu izabranih „%s“."

msgid "Remove all"
msgstr "Ukloni sve"

msgid "Click to remove all chosen %s at once."
msgstr "Kliknite da uklonite sve izabrane „%s“ odjednom."

msgid "%s selected option not visible"
msgid_plural "%s selected options not visible"
msgstr[0] "%s izabrana opcija nije vidljiva"
msgstr[1] "%s izabrane opcije nisu vidljive"
msgstr[2] "%s izabranih opcija nije vidljivo"

msgid "%(sel)s of %(cnt)s selected"
msgid_plural "%(sel)s of %(cnt)s selected"
msgstr[0] "%(sel)s od %(cnt)s izabrano"
msgstr[1] "%(sel)s od %(cnt)s izabrano"
msgstr[2] "%(sel)s od %(cnt)s izabrano"

msgid ""
"You have unsaved changes on individual editable fields. If you run an "
"action, your unsaved changes will be lost."
msgstr ""
"Imate nesačuvane izmene u poljima. Ako pokrenete akciju, nesačuvane izmene "
"će biti izgubljene."

msgid ""
"You have selected an action, but you haven’t saved your changes to "
"individual fields yet. Please click OK to save. You’ll need to re-run the "
"action."
msgstr ""
"Izabrali ste akciju, ali niste sačuvali izmene u poljima. Kliknite OK da "
"sačuvate, zatim ponovo pokrenite akciju."

msgid ""
"You have selected an action, and you haven’t made any changes on individual "
"fields. You’re probably looking for the Go button rather than the Save "
"button."
msgstr ""
"Izabrali ste akciju bez izmena u poljima. Verovatno vam treba dugme Primeni,"
" a ne Sačuvaj."

